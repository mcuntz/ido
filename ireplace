set -e

trap cleanup 1 2 3 6

prog=$0
pprog=$(basename ${prog})
dprog=$(dirname ${prog})
isdir=${PWD}
pid=$$
TMP=${TMPDIR:-"/tmp"}

# --------------------------------------------------------------------
# Functions
#
function usage () {
    printf "${pprog} [-h] [-e expr] [expr] infiles\n"
    printf "Applies sed expression on several files,"
    printf " e.g. replacing a string in the files.\n"
    printf "\n"
    printf "Input\n"
    printf "    expr         sed expression such as 's/str1/str2/' or"
    printf " 'y/abc/ABC/'.\n"
    printf "    infiles      Files to apply sed expression interactively."
    printf " Filenames can include spaces.\n"
    printf "\n"
    printf "Options\n"
    printf "    -e sed_expr  Append the sed expression to the list of"
    printf " commands for sed."
    printf " Can be provided several times. If -e is provided, only"
    printf " filenames and no sed expression should be given as command"
    printf " line arguments.\n"
    printf "    -h           Prints this help screen.\n"
    printf "\n"
    printf "Examples\n"
    printf "    ${pprog} '/exp/s/exp=.*/exp=moc01/' moc.*\n"
    printf "    ${pprog} -e '/exp/s/exp=.*/exp=moc01/'"
    printf " -e '/name/s/name=.*/name=itest/' moc.*\n"
    printf "\n"
    printf "Copyright (c) 2012-2026 Matthias Cuntz - mc (at) macu (dot) de\n"
}

# cleanup
function cleanup ()
{
    \rm -f ${TMP}/*.${pid}*
    exit 1
}

# --------------------------------------------------------------------
# Command line arguments
#

# Get options
while getopts "e:h" Option ; do
    case ${Option} in
      e) sedstr+=("${OPTARG}");;
      h) usage; exit;;
      *) printf "Error ${pprog}: unimplemented option.\n\n" 1>&2
         usage 1>&2; exit 1;;
    esac
done
shift $((${OPTIND} - 1))

# Get sed expression
if [[ -n ${sedstr} ]] ; then
    sedcmd=""
    for s in "${sedstr[@]}" ; do
	sedcmd="${sedcmd} -e \"${s}\""
    done
else
    sedcmd="-e \"${1}\""
    shift 1
fi

# Check that input file left after sed expression
if [ $# -lt 1 ] ; then
    printf "Error ${pprog}: sed expression and input files" 1>&2
    printf " must be given.\n\n" 1>&2
    usage 1>&2
    exit 1
fi

# --------------------------------------------------------------------
# Replace
#

for i in "$@" ; do
    if [[ $(file "${i}" | cut -d ' ' -f 2) != 'directory' ]] ; then
	# echo sed "${sedcmd}" "${i}"
        eval sed "${sedcmd}" "${i}" > ${TMP}/tmp.${pid}
        set +e
        tt=$(diff "${i}" ${TMP}/tmp.${pid})
        set -e
        if [[ "${tt}" == "" ]] ; then
            # delete if nothing was replaced
            rm ${TMP}/tmp.${pid}
        else
            # file permissions, check for different utilities first
            # on GNU: chmod --reference=old new
            # on Unix: chmod $(stat -f '%OLp' old) new
            set +e
            # Recover error message if any, i.e. GNU
            testit=$(stat -f '%OLp' "${i}" 2>&1 > /dev/null)
            set -e
            if [[ "${testit}z" == "z" ]] ; then # Unix
                chmod $(stat -f '%OLp' "${i}") ${TMP}/tmp.${pid}
            else                                # GNU
                chmod --reference="${i}" ${TMP}/tmp.${pid}
            fi
            mv ${TMP}/tmp.${pid} "${i}"
        fi
    fi
done

exit 0
