#          Matthias Cuntz, Jan 2023
#              - /usr/env/bin bash instead of /bin/bash
#              - correct stat -f '%OLp' from stat -f '%p'
#          Matthias Cuntz, Mar 2026
#              - add -e option(s)
#              - sdiff to diff because of speed
